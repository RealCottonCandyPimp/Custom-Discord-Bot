DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_GUILD_ID=your_test_guild_id

# MySQL (guild settings: prefix + per-command toggles)
MYSQL_HOST=127.0.0.1
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=discord_bot

# Dashboard (Discord OAuth + session)
# Add this exact URL under OAuth2 → Redirects in the Discord Developer Portal
DASHBOARD_CALLBACK_URL=http://127.0.0.1:3000/auth/discord/callback
# Long random string for express-session
SESSION_SECRET=change_me_to_a_long_random_string
# Optional; default 3000
DASHBOARD_PORT=3000
# Set to true when serving the dashboard only over HTTPS
# DASHBOARD_COOKIE_SECURE=true
